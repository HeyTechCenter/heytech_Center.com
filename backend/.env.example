# ── Serveur ──────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────
# Remplace par ton URI MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/heytech?retryWrites=true&w=majority

# ── Email (Gmail) ─────────────────────────────────
# L'adresse Gmail officielle de HeyTech Center
EMAIL_USER=heytech@gmail.com
# Mot de passe d'application Gmail (pas ton vrai mot de passe)
# Générer ici : https://myaccount.google.com/apppasswords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── CORS ─────────────────────────────────────────
# En développement
CORS_ORIGIN=http://localhost:3000
# En production (remplace par ton vrai domaine)
# CORS_ORIGIN=https://heytech-center.com
